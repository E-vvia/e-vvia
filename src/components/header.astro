---
import MenuLinksAstroComponent from "./header/menu-links.astro";
---

<div class="relative">
    <header id="header" class="surface standard-p rounded-b-xl font-special">
        <div class="flex items-center justify-between">
            <h1 class="text-3xl sm:text-4xl animate-text-color">
                <a href="/">E-vvia</a>
            </h1>

            <nav class="hidden md:block">
                <ul class="flex gap-5">
                    <MenuLinksAstroComponent />
                </ul>
            </nav>

            <button
                id="menu-button"
                class="md:hidden text-2xl"
                aria-label="Open menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"
                    ></path>
                </svg>
            </button>
        </div>
    </header>
    <nav
        id="mobile-menu"
        class="absolute top-full left-0 w-full z-10
           md:hidden surface font-special rounded-b-xl
           invisible opacity-0 -translate-y-2
           transition-all duration-200 ease-out
           pointer-events-none"
    >
        <ul class="flex flex-col gap-4 p-5">
            <MenuLinksAstroComponent />
        </ul>
    </nav>
</div>

<script>
    const button = document.querySelector("#menu-button");
    const menu = document.querySelector("#mobile-menu");
    const header = document.querySelector("#header");

    button?.addEventListener("click", () => {
        menu?.classList.toggle("invisible");
        menu?.classList.toggle("opacity-0");
        menu?.classList.toggle("-translate-y-2");
        menu?.classList.toggle("pointer-events-none");

        menu?.classList.toggle("opacity-100");
        menu?.classList.toggle("translate-y-0");

        header?.classList.toggle('rounded-b-xl')
    });
</script>

<style>
    html[data-theme="dark"] .animate-text-color {
        animation: text-color-cycle 4s ease-in-out infinite;
    }

    html[data-theme="light"] .animate-text-color {
        animation: text-color-cycle 4s ease-in-out infinite;
    }

    @keyframes text-color-cycle {
        0% {
            color: var(--color-rose-500);
        }

        25% {
            color: var(--color-violet-500);
        }

        50% {
            color: var(--color-sky-500);
        }

        75% {
            color: var(--color-emerald-500);
        }

        100% {
            color: var(--color-rose-500);
        }
    }
</style>
