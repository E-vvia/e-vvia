---
import BaseLayout from "../layouts/base-layout.astro";
import Card from "../components/card.astro";
import { Image } from "astro:assets";
import AdditionalMemory from "../assets/images/additional_memory.gif";
import CardAstroComponent from "../components/card.astro";
---

<BaseLayout>
    <div class="h-lvh flex justify-center items-center">
        <div
            class="max-w-xl rounded-2xl bg-white/80 dark:bg-black/60 backdrop-blur-md shadow-xl p-8 text-center"
        >
            <h1
                class="text-4xl md:text-6xl font-extrabold tracking-tight text-black dark:text-white"
            >
                404 - NOT FOUND
            </h1>

            <Image
                src={AdditionalMemory}
                alt="Ayano in additional memory gif"
                class="mt-8 mx-auto w-64 md:w-80 rounded-lg shadow-lg"
            />

            <div class="mt-8">
                <CardAstroComponent>
                    <div class="space-y-3">
                        <p>The page you were looking for was not found...</p>

                        <p>
                            Maybe you were looking for an
                            <a
                                href="https://www.youtube.com/watch?v=q2QfH1JqtkY&list=RDq2QfH1JqtkY"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="ml-1 font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300 transition-colors"
                            >
                                Additional Memory
                            </a>?
                        </p>
                    </div>
                </CardAstroComponent>
            </div>
        </div>
    </div>
</BaseLayout>
